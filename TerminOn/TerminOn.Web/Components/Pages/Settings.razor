@page "/settings"
@using TerminOn.Application.Model
@using TerminOn.Application.Services
@inject DoctorService DoctorService
@inject LocationService LocationService
@rendermode InteractiveServer

<PageTitle>Einstellungen & Stammdaten</PageTitle>

<div class="container-fluid px-4 py-4">
    
    <!-- MCW Header -->
    <div class="pb-3 mb-4 border-bottom">
        <h1 class="h3 mb-1 fw-bold text-dark" style="letter-spacing: -0.5px;">System-Einstellungen</h1>
        <p class="text-muted small mb-0">Verwaltung der Praxis-Infrastruktur und des Personals</p>
    </div>

    <div class="row g-4">
        
        <!-- LINKE SPALTE: Ärzte-Verwaltung -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-4 h-100">
                <h5 class="fw-bold text-dark mb-1">👨‍⚕️ Ärzte & Mediziner</h5>
                <p class="text-muted small mb-4">Verfügbare Ärzte im System hinterlegen</p>

                <!-- Schnell-Anlegen Formular (Erweitert um E-Mail) -->
                <div class="d-flex flex-column gap-2 mb-4">
                    <div class="input-group shadow-sm rounded-3 overflow-hidden">
                        <input type="text" class="form-control border-0 bg-light" placeholder="Vorname" @bind="newDocFirstname" />
                        <input type="text" class="form-control border-0 bg-light border-start" placeholder="Nachname" @bind="newDocLastname" />
                    </div>
                    <div class="input-group shadow-sm rounded-3 overflow-hidden">
                        <input type="email" class="form-control border-0 bg-light" placeholder="E-Mail-Adresse" @bind="newDocEmail" />
                        <button class="btn text-white px-4" style="background-color: #2b4c7e;" @onclick="AddDoctorAsync">Hinzufügen</button>
                    </div>
                </div>

                <!-- Liste -->
                <div class="list-group list-group-flush border-top">
                    @if (doctors == null)
                    {
                        <p class="text-muted small my-3 text-center">Lade Ärzte...</p>
                    }
                    else if (!doctors.Any())
                    {
                        <p class="text-muted italic small my-3 text-center">Keine Ärzte registriert.</p>
                    }
                    else
                    {
                        @foreach (var doc in doctors)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3 border-bottom">
                                <div>
                                    <span class="fw-semibold text-dark d-block">Dr. @doc.Firstname @doc.Lastname</span>
                                    <span class="text-muted small">📧 @doc.Email</span>
                                </div>
                                <button class="btn btn-sm btn-outline-danger border-0" @onclick="() => DeleteDoctorAsync(doc.Id)">🗑️</button>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- RECHTE SPALTE: Räume / Ordinationen -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-4 h-100">
                <h5 class="fw-bold text-dark mb-1">🏢 Räume & Ordinationen</h5>
                <p class="text-muted small mb-4">Räumlichkeiten für das Kalender-Grid definieren</p>

                <!-- Schnell-Anlegen Formular (Erweitert um Raumnummer) -->
                <div class="input-group mb-4 shadow-sm rounded-3 overflow-hidden">
                    <input type="text" class="form-control border-0 bg-light" placeholder="Raumname (z.B. Ordination 1)" @bind="newLocName" />
                    <input type="text" class="form-control border-0 bg-light border-start" placeholder="Raumnr." @bind="newLocRoomNumber" style="max-width: 120px;" />
                    <button class="btn text-white px-4" style="background-color: #2b4c7e;" @onclick="AddLocationAsync">Hinzufügen</button>
                </div>

                <!-- Liste -->
                <div class="list-group list-group-flush border-top">
                    @if (locations == null)
                    {
                        <p class="text-muted small my-3 text-center">Lade Räume...</p>
                    }
                    else if (!locations.Any())
                    {
                        <p class="text-muted italic small my-3 text-center">Keine Räume angelegt.</p>
                    }
                    else
                    {
                        @foreach (var loc in locations)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3 border-bottom">
                                <div>
                                    <span class="fw-semibold text-dark">🏢 @loc.Name</span>
                                    <span class="badge bg-light text-secondary border ms-2">Raum: @loc.RoomNumber</span>
                                </div>
                                <button class="btn btn-sm btn-outline-danger border-0" @onclick="() => DeleteLocationAsync(loc.Id)">🗑️</button>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    private List<Doctor>? doctors;
    private List<Location>? locations;

    // Formular-Zustände
    private string newDocFirstname = "";
    private string newDocLastname = "";
    private string newDocEmail = "";
    private string newLocName = "";
    private string newLocRoomNumber = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        doctors = await DoctorService.GetAllDoctorsAsync();
        locations = await LocationService.GetAllLocationsAsync();
    }

    private async Task AddDoctorAsync()
    {
        if (!string.IsNullOrWhiteSpace(newDocFirstname) && 
            !string.IsNullOrWhiteSpace(newDocLastname) && 
            !string.IsNullOrWhiteSpace(newDocEmail))
        {
            // Reicht jetzt alle 3 verlangten Argumente an den Konstruktor weiter!
            var doc = new Doctor(newDocFirstname, newDocLastname, newDocEmail);
            await DoctorService.AddDoctorAsync(doc);
            
            newDocFirstname = "";
            newDocLastname = "";
            newDocEmail = "";
            await LoadDataAsync();
        }
    }

    private async Task AddLocationAsync()
    {
        if (!string.IsNullOrWhiteSpace(newLocName) && !string.IsNullOrWhiteSpace(newLocRoomNumber))
        {
            // Reicht beide verlangten Argumente an den Konstruktor weiter!
            var loc = new Location(newLocName, newLocRoomNumber);
            await LocationService.AddLocationAsync(loc);
            
            newLocName = "";
            newLocRoomNumber = "";
            await LoadDataAsync();
        }
    }

    private async Task DeleteDoctorAsync(int id)
    {
        await DoctorService.DeleteDoctorAsync(id);
        await LoadDataAsync();
    }

    private async Task DeleteLocationAsync(int id)
    {
        await LocationService.DeleteLocationAsync(id);
        await LoadDataAsync();
    }
}