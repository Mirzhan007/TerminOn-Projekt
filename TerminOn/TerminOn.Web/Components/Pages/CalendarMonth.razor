@page "/calendar/month"
@using System.Globalization
@using TerminOn.Application.Model
@using TerminOn.Application.Services
@inject AppointmentService AppointmentService
@rendermode InteractiveServer

<PageTitle>Monatsansicht - TerminOn</PageTitle>

<div class="container-fluid px-4 py-4 bg-white min-vh-100">
    
    <!-- 1. OBERER HEADER (Perfekt synchron mit Tag und Woche) -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="fw-bold text-dark mb-0" style="font-size: 1.85rem; letter-spacing: -0.5px;">Ihr Kalender <span class="text-muted fw-light">&gt;</span></h1>
            <p class="text-muted small mb-0 ps-1">Josef Keliner Gasse 1</p>
        </div>
        
        <div class="d-flex gap-2">
           <a href="book-appointment" class="btn btn-outline-primary px-4 py-2 small fw-semibold" style="border-color: #2b4c7e; color: #2b4c7e; border-radius: 6px; text-decoration: none;">Termin Buchen</a>
            <button class="btn btn-danger px-4 py-2 small fw-bold shadow-sm" style="background-color: #e07a5f; border: none; border-radius: 6px;">AKUT</button>
        </div>
    </div>

    <!-- 2. SUB-NAVIGATION (Konsolidiert auf eine Zeile mit funktionstüchtigen Tabs) -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 py-2 border-bottom border-top border-light">
        <div class="d-flex align-items-center gap-2">
            <h2 class="h5 mb-0 fw-bold text-dark text-uppercase" style="letter-spacing: 0.5px;">@currentDate.ToString("MMMM yyyy") &gt;</h2>
            <button class="btn btn-sm btn-light border px-2 py-1 ms-2" @onclick="NavigatePrevious">◀</button>
            <button class="btn btn-sm btn-light border px-3 py-1 small" @onclick="SetToToday">Heute</button>
            <button class="btn btn-sm btn-light border px-2 py-1" @onclick="NavigateNext">▶</button>
        </div>

        <!-- Die MCW Navigations-Tabs -->
        <div class="btn-group p-1 bg-light rounded-3 border" style="font-size: 0.85rem;">
            <a href="calendar/month" class="btn btn-sm bg-white shadow-sm text-primary rounded-2 fw-medium px-3">Monat</a>
            <a href="calendar/week" class="btn btn-sm text-secondary border-0 px-3">Woche</a>
            <a href="calendar/day" class="btn btn-sm text-secondary border-0 px-3">Tag</a>
        </div>
    </div>

    <!-- 3. MONATS-GRID -->
    @if (appointments == null)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted small mt-2">Lade Monatsraster...</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden mt-4">
            <!-- Wochentage-Header -->
            <div class="d-grid text-center py-2 border-bottom" style="grid-template-columns: repeat(7, 1fr); background-color: #f8fafc; font-size: 0.8rem;">
                @foreach (var dayName in CultureInfo.CurrentCulture.DateTimeFormat.AbbreviatedDayNames.Skip(1).Concat(CultureInfo.CurrentCulture.DateTimeFormat.AbbreviatedDayNames.Take(1)))
                {
                    <div class="fw-bold text-muted text-uppercase py-1" style="letter-spacing: 0.5px;">@dayName</div>
                }
            </div>
            
            <!-- Kalendertage-Grid -->
            <div class="d-grid bg-light" style="grid-template-columns: repeat(7, 1fr); gap: 1px;">
                @foreach (var cell in GetMonthGridCells())
                {
                    <div class="p-2 bg-white position-relative d-flex flex-column justify-content-between" style="min-height: 115px; transition: background-color 0.2s;">
                        @if (cell.HasValue)
                        {
                            var dayAppointments = appointments.Where(a => a.Date == cell.Value).ToList();
                            
                            <div>
                                <!-- Highlight für den heutigen Tag im Monat -->
                                <span class="fw-bold small d-inline-block mb-2 text-center rounded-circle @(cell.Value == DateOnly.FromDateTime(DateTime.Today) ? "bg-primary text-white" : "text-secondary")" 
                                      style="@(cell.Value == DateOnly.FromDateTime(DateTime.Today) ? "width: 24px; height: 24px; line-height: 24px;" : "")">
                                    @cell.Value.Day
                                </span>
                                
                                <!-- Kompakt gerenderte Termin-Badges -->
                                <div class="d-flex flex-column gap-1 overflow-hidden" style="max-height: 70px;">
                                    @foreach (var app in dayAppointments.Take(2))
                                    {
                                        <div class="px-2 py-1 rounded text-white text-truncate shadow-sm fw-medium" 
                                             style="background-color: @GetColorForCard(app.Patient?.Lastname); font-size: 0.7rem; line-height: 1.2; cursor: pointer;">
                                            ⏱️ @app.Patient?.Lastname
                                        </div>
                                    }
                                    @if (dayAppointments.Count > 2)
                                    {
                                        <div class="text-muted text-center fw-semibold mt-1" style="font-size: 0.65rem; letter-spacing: 0.2px;">
                                            + @(dayAppointments.Count - 2) weitere
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private DateOnly currentDate = DateOnly.FromDateTime(new DateTime(2020, 2, 22)); // Synchroner Start-Monat für Demodaten
    private List<Appointment>? appointments;

    protected override async Task OnInitializedAsync() => await LoadDataAsync();

    private async Task LoadDataAsync()
    {
        var startOfMonth = new DateOnly(currentDate.Year, currentDate.Month, 1);
        var endOfMonth = startOfMonth.AddMonths(1).AddDays(-1);
        appointments = await AppointmentService.GetAppointmentsByRangeAsync(startOfMonth, endOfMonth);
    }

    private async Task SetToToday() { currentDate = DateOnly.FromDateTime(DateTime.Today); await LoadDataAsync(); }
    private async Task NavigatePrevious() { currentDate = currentDate.AddMonths(-1); await LoadDataAsync(); }
    private async Task NavigateNext() { currentDate = currentDate.AddMonths(1); await LoadDataAsync(); }

    // Identische Farbzuweisung wie bei Tag & Woche für ein konsistentes Look-and-Feel
    private string GetColorForCard(string? lastname)
    {
        if (lastname == "Alexander") return "#3a5a85"; // Deep Medical Blue
        if (lastname == "Berger") return "#5fa8f2";    // Hellblau
        if (lastname == "Bingen") return "#5cbda3";    // Mintgrün
        if (lastname == "Merte") return "#e27c64";     // Lachs-Rot
        return "#a18ec1";                              // Pastell-Violett
    }

    private List<DateOnly?> GetMonthGridCells()
    {
        var cells = new List<DateOnly?>();
        var startOfMonth = new DateOnly(currentDate.Year, currentDate.Month, 1);
        int daysInMonth = DateTime.DaysInMonth(currentDate.Year, currentDate.Month);
        int offset = (7 + (startOfMonth.DayOfWeek - DayOfWeek.Monday)) % 7;
        
        for (int i = 0; i < offset; i++) cells.Add(null);
        for (int i = 1; i <= daysInMonth; i++) cells.Add(new DateOnly(currentDate.Year, currentDate.Month, i));
        while (cells.Count % 7 != 0) cells.Add(null);
        
        return cells;
    }
}